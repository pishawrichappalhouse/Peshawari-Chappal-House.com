{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product sold in the shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "price", "image", "description", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "size": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Processing", "Confirmed", "Cancelled"] }
      },
      "required": ["userEmail", "customerName", "address", "phone", "items", "total", "date", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "A product review",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["productId", "userEmail", "userName", "rating", "comment", "date"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of product reviews"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
